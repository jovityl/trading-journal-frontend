# Auth0 — create a free account at https://auth0.com
# Create a SPA application and get the domain + client ID
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id

# The identifier you set when creating your Auth0 API
VITE_AUTH0_AUDIENCE=https://trading-journal-api

# URL of the backend API (change if running on a different port)
VITE_API_BASE_URL=https://localhost:7160
